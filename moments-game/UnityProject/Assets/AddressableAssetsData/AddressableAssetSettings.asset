%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &1
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_Script: {fileID: 11500000, guid: addressable-asset-settings-guid, type: 3}
  m_Name: AddressableAssetSettings
  m_EditorClassIdentifier:

  # ── Build settings ────────────────────────────────────────────────
  buildRemoteCatalog: 0
  overridePlayerVersion: 0
  profileName: Default
  buildAddressablesWithPlayerBuild: 0   # false = explicit build step

  # ── Groups ────────────────────────────────────────────────────────
  groups:
  - {fileID: 100000001}  # BuiltInData (default Unity group)
  - {fileID: 200000001}  # Moments_CoreScenes
  - {fileID: 300000001}  # Moments_MiniGameScenes

  # ── Profile variables ──────────────────────────────────────────────
  profileSettings:
    profiles:
    - profileName: Default
      variables:
        LocalBuildPath: '[UnityEngine.AddressableAssets.Addressables.BuildPath]/[BuildTarget]'
        LocalLoadPath:  '{UnityEngine.AddressableAssets.Addressables.RuntimePath}/[BuildTarget]'

--- !u!114 &100000001
MonoBehaviour:
  m_Name: BuiltInData
  m_Script: {fileID: 11500000, guid: built-in-data-group-guid, type: 3}
  m_Group: Default

--- !u!114 &200000001
MonoBehaviour:
  m_Name: Moments_CoreScenes
  m_Script: {fileID: 11500000, guid: addressable-asset-group-guid, type: 3}
  m_EditorClassIdentifier:
  m_Name: Moments_CoreScenes
  entries:
