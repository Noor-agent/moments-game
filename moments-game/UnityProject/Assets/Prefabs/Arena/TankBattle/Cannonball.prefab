%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
# ══════════════════════════════════════════════════════════
# CannonBall Prefab — projectile for Tank Battle.
#
# Components:
#   - MeshFilter:   Sphere (r=0.15)
#   - MeshRenderer: Emissive orange material
#   - SphereCollider: r=0.15, non-trigger, ContinuousDynamic
#   - Rigidbody:    mass=0.1, useGravity=false
#   - CannonballOwner: MonoBehaviour — carries OwnerId string
#   - TrailRenderer: short glowing trail
#
# TankBattleGame.FireCannon() instantiates this, sets velocity,
# tags it "Cannonball", then stamps OwnerId via CannonballOwner.
# TankHitReporter detects tag + reads OwnerId on collision.
# ══════════════════════════════════════════════════════════
--- !u!1 &1
GameObject:
  m_ObjectHideFlags: 0
  serializedVersion: 6
  m_Component:
  - component: {fileID: 4}
  - component: {fileID: 33}
  - component: {fileID: 23}
  - component: {fileID: 136}
  - component: {fileID: 54}
  - component: {fileID: 96}
  - component: {fileID: 114}
  m_Layer: 0
  m_Name: Cannonball
  m_TagString: Cannonball
  m_IsActive: 1
--- !u!4 &4
Transform:
  m_LocalPosition: {x: 0, y: 0, z: 0}
  m_LocalRotation: {x: 0, y: 0, z: 0, w: 1}
  m_LocalScale: {x: 0.3, y: 0.3, z: 0.3}
  m_Father: {fileID: 0}
--- !u!33 &33
MeshFilter:
  m_Mesh: {fileID: 10207, guid: 0000000000000000e000000000000000, type: 0}
--- !u!23 &23
MeshRenderer:
  m_Materials:
  - {fileID: 11400000, guid: cannonball-mat-guid, type: 2}
--- !u!136 &136
SphereCollider:
  m_Radius: 0.5
  m_IsTrigger: 0
--- !u!54 &54
Rigidbody:
  m_Mass: 0.1
  m_UseGravity: 0
  m_IsKinematic: 0
  m_Interpolate: 1
  m_CollisionDetection: 2
--- !u!96 &96
TrailRenderer:
  m_Time: 0.18
  m_StartWidth: 0.15
  m_EndWidth:   0.0
  m_Materials:
  - {fileID: 11400000, guid: trail-orange-mat-guid, type: 2}
--- !u!114 &114
MonoBehaviour:
  m_Script: {fileID: 11500000, guid: cannonball-owner-guid, type: 3}
  m_Name:
  m_EditorClassIdentifier:
